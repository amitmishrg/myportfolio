# Copy to `.env.local` and paste your Web3Forms access key to enable
# actual email delivery from the contact form. If this variable is
# empty or missing, the form falls back to opening the visitor's mail
# client with the message pre-filled.
#
# Grab a free key in ~30 seconds (no signup / dashboard required):
#   1. Go to https://web3forms.com
#   2. Enter the inbox you want messages delivered to
#   3. The access key arrives by email — paste it below
VITE_WEB3FORMS_KEY=
